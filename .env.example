# cp .env.example .env  — dann API Keys eintragen
# Nur die Provider die du nutzen willst, der Rest bleibt weg.

# Kiwix server URL — adapt if your Kiwix runs on a different host/port
KIWIX_URL=https://127.0.0.1:450

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AI...
GROQ_API_KEY=gsk_...
MISTRAL_API_KEY=...
OLLAMA_API_KEY=ollama        # lokales Ollama braucht keinen echten Key
